# Python artifacts (e.g. from byte-compiling skill scripts)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Agent / skill runtime state — generated by hooks at run time, never committed
# (see docs/repository-structure.md and the runtime contract in
# docs/authoring-agents.md)
.agents/
**/logs/
**/status.json

# Local environment / secrets
.env
.env.*
!.env.example

# OS noise
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/
*.swp
*~

# Note: empty skeleton dirs (references/, hooks/, scripts/) are intentionally
# NOT tracked. Git does not store empty directories; they are created on
# demand. See docs/repository-structure.md for when to populate them.
