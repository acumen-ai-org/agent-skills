#!/usr/bin/env python3
"""Aggregate validated report fragments into a standalone HTML report folder.

Usage:
  dev-report-build <release-id> <fragments-dir> <reports-root>
                   [--vcs-ref REF] [--label TEXT] [--no-embed]
                   [--design FILE] [--commits N] [--modules id1,id2,...]

Builds reports/<release-id>/ atomically (temp dir -> move on success only),
upserts reports/releases.json (newest-first by id), and embeds the manifest,
every fragment, and the post-upsert releases.json into index.html so the
folder opens via file:// with no server. data/*.json and the standalone
reports/releases.json are always written too. The releases.json content is
embedded under the data-island key "releases.json" in both embed and
--no-embed modes.

--design FILE reads FILE, extracts every CSS :root{...} block (fenced ```css
or raw), and injects the concatenated rules as one <style id="design-override">
immediately before </head> so it overrides the default app.css theme variables.
A file with no :root block is a non-fatal notice; the default theme is used.

--commits N records commit_count in the manifest release object so the renderer
formats the report title as "<created_at date> Release: N commits"; without it
the commit clause is omitted.

--modules id1,id2,... is a comma-separated list of opaque module ids written
verbatim into the manifest as top-level "modules". The renderer unions them
with module ids found in fragment sections to populate the global module
filter; the ids are never parsed or resolved here.

Exit codes:
  0  report folder written; releases.json updated
  1  bad arguments / usage
  2  I/O failure (unreadable fragments-dir, unwritable reports-root)
  3  one or more fragments failed contract validation (nothing written)
"""
import argparse
import datetime
import json
import pathlib
import re
import shutil
import subprocess
import sys
import tempfile

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent))
from validate_fragments import validate_dir

RELEASE_ID_ALLOWED = set(
    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789._-"
)
DATA_ISLAND_PLACEHOLDER = (
    '<script id="report-data" type="application/json">{}</script>'
)
CATEGORY_LABELS = {
    "architecture": "Architecture",
    "evolution": "Evolution",
    "dependencies": "Dependencies",
    "quality": "Quality",
    "security": "Security",
    "schema": "Schema",
    "contracts": "Contracts",
    "mission": "Mission",
    "test-coverage": "Test coverage",
    "test-reports": "Test reports",
    "overview": "Overview",
}


ROOT_BLOCK_RE = re.compile(r":root\s*\{[^}]*\}", re.IGNORECASE)


def fail(code, message):
    sys.stderr.write(message + "\n")
    return code


def extract_root_blocks(text):
    return [match.group(0).strip() for match in ROOT_BLOCK_RE.finditer(text)]


def build_design_override(design_path):
    text = pathlib.Path(design_path).read_text(encoding="utf-8")
    blocks = extract_root_blocks(text)
    if not blocks:
        return None
    rules = "\n".join(blocks)
    return '<style id="design-override">\n' + rules + "\n</style>\n"


def capture_git_sha():
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--short", "HEAD"],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.stdout.strip() or None
    except (subprocess.CalledProcessError, FileNotFoundError, OSError):
        sys.stderr.write(
            "WARN not a git repository (or git unavailable); git_sha=null\n"
        )
        return None


def build_manifest(parsed, release, modules):
    grouped = {}
    rollup = {"ok": 0, "info": 0, "warn": 0, "error": 0}
    for _, fragment in parsed:
        category = fragment["category"]
        status = fragment["status"]
        if status in rollup:
            rollup[status] += 1
        grouped.setdefault(category, []).append(
            {
                "id": fragment["id"],
                "title": fragment["title"],
                "summary": fragment.get("summary", ""),
                "status": status,
                "severity": fragment.get("severity"),
                "path": f"data/{category}/{fragment['id']}.json",
            }
        )

    categories = []
    for category in sorted(grouped):
        fragments = sorted(grouped[category], key=lambda entry: entry["id"])
        categories.append(
            {
                "id": category,
                "label": CATEGORY_LABELS.get(category, category.title()),
                "fragments": fragments,
            }
        )

    manifest = {
        "schema": "dev-report-manifest/v1",
        "release": release,
        "rollup": rollup,
        "categories": categories,
    }
    if modules:
        manifest["modules"] = modules
    return manifest


def write_json(path, payload):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(
        json.dumps(payload, indent=2, ensure_ascii=False) + "\n",
        encoding="utf-8",
    )


def compute_releases(reports_root, release_entry):
    releases_path = reports_root / "releases.json"
    releases = []
    if releases_path.exists():
        try:
            existing = json.loads(releases_path.read_text(encoding="utf-8"))
            releases = [
                entry
                for entry in existing.get("releases", [])
                if entry.get("id") != release_entry["id"]
            ]
        except (json.JSONDecodeError, OSError):
            releases = []
    releases.insert(0, release_entry)
    releases.sort(key=lambda entry: entry.get("created_at", ""), reverse=True)
    return {"schema": "dev-report-releases/v1", "releases": releases}


def write_releases(reports_root, releases_doc):
    handle = tempfile.NamedTemporaryFile(
        "w",
        encoding="utf-8",
        dir=str(reports_root),
        prefix=".releases-",
        suffix=".json",
        delete=False,
    )
    with handle:
        json.dump(releases_doc, handle, indent=2, ensure_ascii=False)
        handle.write("\n")
    pathlib.Path(handle.name).replace(reports_root / "releases.json")


def main():
    parser = argparse.ArgumentParser(prog="dev-report-build", add_help=True)
    parser.add_argument("release_id")
    parser.add_argument("fragments_dir")
    parser.add_argument("reports_root")
    parser.add_argument("--vcs-ref", default=None)
    parser.add_argument("--label", default=None)
    parser.add_argument("--no-embed", action="store_true")
    parser.add_argument("--design", default=None)
    parser.add_argument("--commits", type=int, default=None)
    parser.add_argument("--modules", default=None)
    try:
        args = parser.parse_args()
    except SystemExit:
        return 1

    release_id = args.release_id
    if not release_id or any(
        character not in RELEASE_ID_ALLOWED for character in release_id
    ):
        return fail(1, f"invalid release-id '{release_id}': must match [A-Za-z0-9._-]+")

    fragments_dir = pathlib.Path(args.fragments_dir)
    reports_root = pathlib.Path(args.reports_root)
    assets_dir = pathlib.Path(__file__).resolve().parent / "assets"

    if not fragments_dir.is_dir():
        return fail(2, f"fragments-dir is not a directory: {fragments_dir}")

    failures, parsed = validate_dir(fragments_dir)
    if failures:
        for name in sorted(failures):
            sys.stderr.write(f"{name}:\n")
            for message in failures[name]:
                sys.stderr.write(f"  - {message}\n")
        return fail(
            3, f"FAIL {len(failures)} fragment(s) invalid — nothing written"
        )

    try:
        reports_root.mkdir(parents=True, exist_ok=True)
    except OSError as error:
        return fail(2, f"cannot create reports-root {reports_root}: {error}")

    git_sha = capture_git_sha()
    created_at = (
        datetime.datetime.now(datetime.timezone.utc)
        .strftime("%Y-%m-%dT%H:%M:%SZ")
    )
    release = {
        "id": release_id,
        "vcs_ref": args.vcs_ref,
        "git_sha": git_sha,
        "created_at": created_at,
        "label": args.label or release_id,
        "commit_count": args.commits,
    }
    modules = []
    if args.modules is not None:
        modules = [item for item in args.modules.split(",") if item]
    manifest = build_manifest(parsed, release, modules)

    design_override = None
    if args.design is not None:
        try:
            design_override = build_design_override(args.design)
        except OSError as error:
            sys.stderr.write(
                f"design: cannot read {args.design}: {error}; "
                "using default theme\n"
            )
        if design_override is None:
            sys.stderr.write(
                f"design: no fenced css :root block in {args.design}; "
                "run references/design-to-theme.md to derive one — "
                "using default theme\n"
            )

    release_entry = {
        "id": release_id,
        "vcs_ref": args.vcs_ref,
        "git_sha": git_sha,
        "created_at": created_at,
        "label": args.label or release_id,
        "commit_count": args.commits,
        "path": f"{release_id}/",
    }
    releases_doc = compute_releases(reports_root, release_entry)

    try:
        staging_root = pathlib.Path(
            tempfile.mkdtemp(prefix=f".build-{release_id}-", dir=str(reports_root))
        )
    except OSError as error:
        return fail(2, f"cannot create staging dir under {reports_root}: {error}")

    try:
        staging = staging_root / release_id
        (staging / "assets").mkdir(parents=True)
        (staging / "data").mkdir(parents=True)

        shutil.copy2(assets_dir / "app.js", staging / "assets" / "app.js")
        shutil.copy2(assets_dir / "app.css", staging / "assets" / "app.css")

        embedded = {"data/manifest.json": manifest}
        write_json(staging / "data" / "manifest.json", manifest)
        for _, fragment in parsed:
            relative = f"data/{fragment['category']}/{fragment['id']}.json"
            write_json(staging / relative, fragment)
            embedded[relative] = fragment

        island_payload = {"releases.json": releases_doc}
        if not args.no_embed:
            island_payload.update(embedded)
        index_html = (assets_dir / "index.html").read_text(encoding="utf-8")
        island = (
            '<script id="report-data" type="application/json">'
            + json.dumps(island_payload, ensure_ascii=False)
            + "</script>"
        )
        index_html = index_html.replace(DATA_ISLAND_PLACEHOLDER, island)
        if design_override is not None:
            index_html = index_html.replace(
                "</head>", design_override + "</head>", 1
            )
        (staging / "index.html").write_text(index_html, encoding="utf-8")

        final = reports_root / release_id
        if final.exists():
            shutil.rmtree(final)
        staging.replace(final)
    except OSError as error:
        shutil.rmtree(staging_root, ignore_errors=True)
        return fail(2, f"build failed: {error}")
    finally:
        shutil.rmtree(staging_root, ignore_errors=True)

    try:
        write_releases(reports_root, releases_doc)
    except OSError as error:
        return fail(2, f"report written but releases.json update failed: {error}")

    embed_note = "embedded" if not args.no_embed else "no-embed (served mode)"
    print(
        f"OK reports/{release_id}/ written "
        f"({len(parsed)} fragments, {embed_note}); releases.json updated"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
